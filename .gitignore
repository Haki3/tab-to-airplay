# Signing key — only needed to pack a .crx. The public key is already in manifest.json
# (it fixes the extension ID), so contributors don't need this private key.
key.pem
.keyinfo

# Native build artifacts (regenerated by install.sh / build.sh)
native/AirPlayCaster.app/
native/airplay-host

# Runtime logs & debug captures
native/proxy.log
native/player.log
native/sample_segment.bin

# macOS / editor cruft
.DS_Store
*.swp

# Python cache
__pycache__/
*.pyc
